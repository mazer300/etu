<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="container">
    <header class="library-header">
        <h1><i class="fas fa-book"></i> Старинная Библиотека</h1>
        <p>Хранилище мудрости веков</p>
    </header>

    <div class="controls">
        <div class="filters">
            <button class="filter active" data-filter="all">
                <i class="fas fa-book"></i> Все книги
            </button>
            <button class="filter" data-filter="available">
                <i class="fas fa-check-circle"></i> В наличии
            </button>
            <button class="filter" data-filter="borrowed">
                <i class="fas fa-user"></i> Выданы
            </button>
            <button class="filter" data-filter="overdue">
                <i class="fas fa-exclamation-triangle"></i> Просрочены
            </button>
        </div>

        <div class="search-box">
            <input type="text" class="search-input" placeholder="Поиск книг..." id="searchInput">
            <i class="fas fa-search search-icon"></i>
        </div>

        <button class="btn-add" id="addBookBtn">
            <i class="fas fa-plus"></i> Добавить книгу
        </button>
    </div>

    <div class="library-decoration"></div>

    <div class="books-grid" id="booksGrid">
        <% books.forEach(book => { %>
            <div class="book-card" data-book-id="<%= book.id %>">
                <div class="book-header">
                    <h3><%= book.title %></h3>
                    <span class="book-year"><%= book.year %></span>
                </div>
                <div class="book-author"><%= book.author %></div>

                <% if (book.description) { %>
                    <div class="book-details">
                        <div class="book-detail">
                            <span>Описание:</span>
                            <span><%= book.description %></span>
                        </div>
                    </div>
                <% } %>

                <div class="book-meta">
                        <span class="status <%= book.status %>">
                            <%= book.status === 'available' ? 'В наличии' :
                                    book.status === 'borrowed' ? 'Выдана' : 'Просрочена' %>
                        </span>
                    <% if (book.borrowedBy && book.dueDate) { %>
                        <div class="borrow-info">
                            <div class="borrower">Читатель: <%= book.borrowedBy %></div>
                            <div class="due-date <%= book.status === 'overdue' ? 'overdue' : '' %>">
                                Вернуть до: <%= new Date(book.dueDate).toLocaleDateString('ru-RU') %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="book-actions">
                    <% if (book.status === 'available') { %>
                        <button class="btn btn-success borrow-btn" data-id="<%= book.id %>">
                            <i class="fas fa-hand-holding"></i> Выдать
                        </button>
                    <% } else { %>
                        <button class="btn btn-warning return-btn" data-id="<%= book.id %>">
                            <i class="fas fa-undo"></i> Вернуть
                        </button>
                    <% } %>

                    <a href="/book/<%= book.id %>" class="btn btn-primary">
                        <i class="fas fa-edit"></i> Карточка
                    </a>

                    <button class="btn btn-danger delete-btn" data-id="<%= book.id %>" data-title="<%= book.title %>">
                        <i class="fas fa-trash"></i> Удалить
                    </button>
                </div>
            </div>
        <% }); %>
    </div>

    <div class="empty-state" id="emptyState" style="display: none;">
        <i class="fas fa-book-open"></i>
        <h3>Библиотека пуста</h3>
        <p>Добавьте первую книгу в вашу коллекцию</p>
    </div>
</div>

<!-- Модальное окно добавления книги -->
<dialog class="dialog" id="addBookDialog">
    <div class="dialog-header">
        <span>Добавить книгу</span>
        <button class="dialog-close" id="closeAddDialog">&times;</button>
    </div>
    <div class="dialog-content">
        <form id="addBookForm">
            <div class="form-group">
                <label for="bookTitle">Название книги *</label>
                <input type="text" id="bookTitle" name="title" required>
            </div>
            <div class="form-group">
                <label for="bookAuthor">Автор *</label>
                <input type="text" id="bookAuthor" name="author" required>
            </div>
            <div class="form-group">
                <label for="bookYear">Год издания *</label>
                <input type="number" id="bookYear" name="year" min="0" max="<%= new Date().getFullYear() %>" required>
                <small class="form-hint">Год должен быть от 0 до <%= new Date().getFullYear() %></small>
            </div>
            <div class="form-group">
                <label for="bookDescription">Описание</label>
                <textarea id="bookDescription" name="description"></textarea>
            </div>
            <div class="dialog-actions">
                <button type="button" class="btn btn-primary" id="cancelAddBtn">Отмена</button>
                <button type="submit" class="btn btn-warning">Добавить</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Модальное окно выдачи книги -->
<dialog class="dialog" id="borrowDialog">
    <div class="dialog-header">
        <span>Выдать книгу</span>
        <button class="dialog-close" id="closeBorrowDialog">&times;</button>
    </div>
    <div class="dialog-content">
        <form id="borrowForm">
            <div class="form-group">
                <label for="borrowerName">Имя читателя *</label>
                <input type="text" id="borrowerName" required>
            </div>
            <div class="form-group">
                <label for="dueDate">Дата возврата *</label>
                <input type="date" id="dueDate" required>
            </div>
            <div class="dialog-actions">
                <button type="button" class="btn btn-primary" id="cancelBorrowBtn">Отмена</button>
                <button type="submit" class="btn btn-warning">Выдать</button>
            </div>
        </form>
    </div>
</dialog>

<!-- Модальное окно подтверждения удаления -->
<dialog class="dialog" id="deleteDialog">
    <div class="dialog-header">
        <span>Подтверждение удаления</span>
        <button class="dialog-close" id="closeDeleteDialog">&times;</button>
    </div>
    <div class="dialog-content">
        <p>Вы уверены, что хотите удалить книгу "<span id="deleteBookTitle"></span>"?</p>
        <div class="dialog-actions">
            <button type="button" class="btn btn-primary" id="cancelDeleteBtn">Отмена</button>
            <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Удалить</button>
        </div>
    </div>
</dialog>

<script src="/js/app.js"></script>
</body>
</html>