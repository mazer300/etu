<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Social Network Admin</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <% if (buildType === 'gulp') { %>
        <link href="/dist-gulp/css/main.min.css" rel="stylesheet">
    <% } else { %>
        <link href="/dist-webpack/css/main.min.css" rel="stylesheet">
    <% } %>

    <style>
        /* ДОПОЛНИТЕЛЬНЫЙ СБРОС СТИЛЕЙ */
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
        }
        .vk-layout {
            min-height: 100vh;
            background: #EDEEF0;
            padding-top: 0 !important;
            margin-top: 0 !important;
        }
    </style>
</head>
<body class="vk-layout">
<!-- Навигация VK -->
<nav class="navbar navbar-expand-lg navbar-vk">
    <div class="container-vk">
        <a class="navbar-brand" href="/?build=<%= buildType %>" title="Social Network Admin">
            <i class="fas fa-users me-2"></i>Social Network Admin
        </a>

        <!-- Выбор сборки -->
        <div class="navbar-nav">
            <div class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false" title="Выбор сборки">
                    <i class="fas fa-tools me-2"></i>
                    <span class="build-text">Сборка: <span class="fw-bold"><%= buildType %></span></span>
                </a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="?build=gulp">
                            <i class="fas fa-cube me-2"></i>Gulp сборка
                        </a></li>
                    <li><a class="dropdown-item" href="?build=webpack">
                            <i class="fas fa-cogs me-2"></i>Webpack сборка
                        </a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container-vk">
    <!-- Основной контент -->
    <div class="main-content">
        <!-- Заголовок и кнопки -->
        <div class="card-vk mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-users me-2 text-primary"></i>
                        Все пользователи
                    </h4>
                    <div class="header-actions">
                            <span class="badge-vk badge-primary">
                                <i class="fas fa-user-friends me-1"></i>
                                <%= users.length %> пользователей
                            </span>
                        <button class="btn-add-user" data-bs-toggle="modal" data-bs-target="#addUserModal">
                            <i class="fas fa-plus"></i>Добавить
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Сетка пользователей (4 колонки) -->
        <div class="users-grid">
            <% users.forEach(user => { %>
                <div class="user-card-container">
                    <div class="card-vk user-card-vk">
                        <div class="card-body">
                            <!-- Заголовок пользователя -->
                            <div class="user-header">
                                <%- renderAvatar(user, 'user-avatar-vk') %>
                                <div class="user-info">
                                    <div class="user-name"><%= user.name %></div>
                                    <div class="user-meta">
                                        <div class="meta-item">
                                            <i class="fas fa-envelope"></i>
                                            <%= user.email %>
                                        </div>
                                        <div class="meta-item">
                                            <i class="fas fa-birthday-cake"></i>
                                            <%= new Date(user.birthDate).toLocaleDateString('ru-RU') %>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Статистика -->
                            <div class="user-stats">
                                <div class="stat-item">
                                    <span class="stat-number"><%= user.stats?.friends || 0 %></span>
                                    <span class="stat-label">друзей</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-number"><%= user.stats?.photos || 0 %></span>
                                    <span class="stat-label">фото</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-number"><%= user.stats?.posts || 0 %></span>
                                    <span class="stat-label">постов</span>
                                </div>
                            </div>

                            <!-- Статус и роль -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge-vk <%= user.role === 'admin' ? 'badge-danger' :
                                        user.role === 'moderator' ? 'badge-warning' : 'badge-primary' %>">
                                    <i class="fas fa-<%=
                                        user.role === 'admin' ? 'crown' :
                                                user.role === 'moderator' ? 'shield-alt' : 'user'
                                    %> me-1"></i>
                                    <%= user.role === 'admin' ? 'Админ' :
                                            user.role === 'moderator' ? 'Модератор' : 'Пользователь' %>
                                </span>
                                <span class="badge-vk <%= user.status === 'active' ? 'badge-success' :
                                        user.status === 'blocked' ? 'badge-danger' : 'badge-warning' %>">
                                    <%= user.status === 'active' ? 'Активен' :
                                            user.status === 'blocked' ? 'Заблокирован' : 'Ожидает' %>
                                </span>
                            </div>

                            <!-- Основные кнопки -->
                            <div class="d-grid gap-2 mb-2">
                                <a href="/users/<%= user.id %>/edit?build=<%= buildType %>"
                                   class="btn btn-vk btn-primary btn-sm">
                                    <i class="fas fa-edit me-1"></i>Редактировать
                                </a>
                                <div class="d-flex gap-1">
                                    <a href="/friends/<%= user.id %>?build=<%= buildType %>"
                                       class="btn btn-vk btn-secondary btn-sm flex-fill">
                                        <i class="fas fa-user-friends me-1"></i>Друзья
                                    </a>
                                    <a href="/news/<%= user.id %>?build=<%= buildType %>"
                                       class="btn btn-vk btn-secondary btn-sm flex-fill">
                                        <i class="fas fa-newspaper me-1"></i>Новости
                                    </a>
                                </div>
                            </div>

                            <!-- Кнопки действий -->
                            <div class="user-actions">
                                <% if (user.avatarBlocked) { %>
                                    <button class="btn-action btn-success" onclick="toggleAvatarBlock(<%= user.id %>, false)">
                                        <i class="fas fa-check me-1"></i>Разблок.
                                    </button>
                                <% } else { %>
                                    <button class="btn-action btn-block" onclick="toggleAvatarBlock(<%= user.id %>, true)">
                                        <i class="fas fa-ban me-1"></i>Блок. аватар
                                    </button>
                                <% } %>
                                <button class="btn-action btn-delete" onclick="deleteUser(<%= user.id %>)">
                                    <i class="fas fa-trash me-1"></i>Удалить
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Пустое состояние -->
        <% if (users.length === 0) { %>
            <div class="card-vk text-center py-5">
                <div class="card-body">
                    <i class="fas fa-users fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Пользователи не найдены</h5>
                    <p class="text-muted mb-3">Нет зарегистрированных пользователей в системе</p>
                    <button class="btn-add-user" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="fas fa-plus me-1"></i>Добавить первого пользователя
                    </button>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Модальное окно добавления пользователя -->
<div class="modal fade modal-vk" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addUserModalLabel">
                    <i class="fas fa-user-plus me-2"></i>Добавить пользователя
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addUserForm" class="add-user-form">
                    <div class="form-group">
                        <label for="newUserName">ФИО *</label>
                        <input type="text" class="form-control" id="newUserName" name="name" required maxlength="100" placeholder="Введите полное имя">
                        <div class="form-text">Полное имя пользователя</div>
                    </div>

                    <div class="form-group">
                        <label for="newUserEmail">Email *</label>
                        <input type="email" class="form-control" id="newUserEmail" name="email" required placeholder="example@mail.ru">
                        <div class="form-text">Уникальный email адрес</div>
                    </div>

                    <div class="form-group">
                        <label for="newUserBirthDate">Дата рождения *</label>
                        <input type="date" class="form-control" id="newUserBirthDate" name="birthDate" required
                               min="1900-01-01" max="<%= new Date().toISOString().split('T')[0] %>">
                        <div class="form-text">Дата рождения пользователя</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="newUserRole">Роль *</label>
                                <select class="form-select" id="newUserRole" name="role" required>
                                    <option value="user">Пользователь</option>
                                    <option value="moderator">Модератор</option>
                                    <option value="admin">Администратор</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="newUserStatus">Статус *</label>
                                <select class="form-select" id="newUserStatus" name="status" required>
                                    <option value="active">Активен</option>
                                    <option value="pending">Не подтверждён</option>
                                    <option value="blocked">Заблокирован</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-vk btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-vk btn-primary" onclick="addNewUser()">
                    <i class="fas fa-save me-1"></i>Добавить пользователя
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Функция добавления пользователя
    function addNewUser() {
        const form = document.getElementById('addUserForm');
        const formData = new FormData(form);

        const userData = {
            name: formData.get('name'),
            email: formData.get('email'),
            birthDate: formData.get('birthDate'),
            role: formData.get('role'),
            status: formData.get('status')
        };

        // Валидация
        if (!userData.name || !userData.email || !userData.birthDate || !userData.role || !userData.status) {
            alert('Пожалуйста, заполните все обязательные поля');
            return;
        }

        // Валидация email
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(userData.email)) {
            alert('Пожалуйста, введите корректный email адрес');
            return;
        }

        // Валидация даты рождения
        const birthDate = new Date(userData.birthDate);
        const today = new Date();
        if (birthDate > today) {
            alert('Дата рождения не может быть в будущем');
            return;
        }

        fetch('/api/users', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(userData)
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Пользователь успешно добавлен');
                    // Закрываем модальное окно
                    const modal = bootstrap.Modal.getInstance(document.getElementById('addUserModal'));
                    modal.hide();
                    // Обновляем страницу
                    location.reload();
                } else {
                    alert('Ошибка при добавлении пользователя: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Ошибка при добавлении пользователя');
            });
    }

    // Функция удаления пользователя
    function deleteUser(userId) {
        if (confirm('Вы уверены, что хотите удалить этого пользователя?')) {
            fetch(`/api/users/${userId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Пользователь успешно удален');
                        location.reload();
                    } else {
                        alert('Ошибка при удалении пользователя: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Ошибка при удалении пользователя');
                });
        }
    }

    // Функция блокировки/разблокировки аватарки
    function toggleAvatarBlock(userId, block) {
        const action = block ? 'block' : 'unblock';
        const confirmMessage = block
            ? 'Заблокировать аватарку пользователя?'
            : 'Разблокировать аватарку пользователя?';

        if (confirm(confirmMessage)) {
            const endpoint = block ? 'block-avatar' : 'unblock-avatar';

            fetch(`/api/users/${userId}/${endpoint}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(`Аватарка пользователя ${block ? 'заблокирована' : 'разблокирована'}`);
                        location.reload();
                    } else {
                        alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} аватарки: ` + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} аватарки`);
                });
        }
    }

    // Очистка формы при закрытии модального окна
    document.getElementById('addUserModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('addUserForm').reset();
    });
</script>

<% if (buildType === 'gulp') { %>
    <script src="/dist-gulp/js/main.min.js"></script>
<% } else { %>
    <script src="/dist-webpack/js/main.min.js"></script>
<% } %>
</body>
</html>