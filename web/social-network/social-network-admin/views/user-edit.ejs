<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <% if (buildType === 'gulp') { %>
        <link href="/dist-gulp/css/main.min.css" rel="stylesheet">
    <% } else { %>
        <link href="/dist-webpack/css/main.min.css" rel="stylesheet">
    <% } %>

    <style>
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
        }
        .vk-layout {
            min-height: 100vh;
            background: #EDEEF0;
            padding-top: 0 !important;
            margin-top: 0 !important;
        }
        .navbar-brand {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }
        .avatar-section {
            position: sticky;
            top: 80px;
            height: fit-content;
        }
        .edit-profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #D7D8D9;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
        }
        .edit-profile-avatar.default-avatar,
        .edit-profile-avatar.blocked-avatar {
            font-size: 36px;
        }
    </style>
</head>
<body class="vk-layout">
<!-- Навигация VK -->
<nav class="navbar navbar-expand-lg navbar-vk">
    <div class="container-vk">
        <a class="navbar-brand" href="/?build=<%= buildType %>" title="Social Network Admin">
            <i class="fas fa-users me-2"></i>Social Network Admin
        </a>
        <div class="navbar-nav">
            <div class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" title="Выбор сборки">
                    <i class="fas fa-tools me-1"></i>
                    <span class="build-text">Сборка: <span class="fw-bold"><%= buildType %></span></span>
                </a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="?build=gulp">Gulp сборка</a></li>
                    <li><a class="dropdown-item" href="?build=webpack">Webpack сборка</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container-vk">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/?build=<%= buildType %>" class="btn btn-vk btn-secondary me-3">
                <i class="fas fa-arrow-left me-1"></i>Назад
            </a>
            <h1 class="d-inline-block page-title">
                <i class="fas fa-edit me-2"></i><%= title %>
            </h1>
        </div>
    </div>

    <div class="edit-form-container">
        <div class="card-vk">
            <div class="card-body">
                <form id="editUserForm" action="/users/<%= user.id %>/update?build=<%= buildType %>" method="POST" onsubmit="return validateForm()">
                    <div class="row mb-4">
                        <div class="col-md-4 text-center avatar-section">
                            <!-- Фиксированная секция аватарки -->
                            <div class="avatar-container">
                                <%- renderAvatar(user, 'edit-profile-avatar mb-3') %>
                                <p class="text-muted small">ID: <%= user.id %></p>

                                <!-- Кнопка блокировки/разблокировки -->
                                <% if (user.avatarBlocked) { %>
                                    <button type="button" class="btn btn-vk btn-success btn-sm w-100 mb-2" onclick="toggleAvatarBlock(<%= user.id %>, false)">
                                        <i class="fas fa-check me-1"></i>Разблокировать аватар
                                    </button>
                                <% } else { %>
                                    <button type="button" class="btn btn-vk btn-warning btn-sm w-100 mb-2" onclick="toggleAvatarBlock(<%= user.id %>, true)">
                                        <i class="fas fa-ban me-1"></i>Заблокировать аватар
                                    </button>
                                <% } %>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="form-section">
                                <h5 class="mb-3"><i class="fas fa-user me-2"></i>Основная информация</h5>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="name" class="form-label">ФИО *</label>
                                        <input type="text" class="form-control" id="name" name="name"
                                               value="<%= user.name %>" required maxlength="100">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="email" class="form-label">Email *</label>
                                        <input type="email" class="form-control" id="email" name="email"
                                               value="<%= user.email %>" required>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="role" class="form-label">Роль *</label>
                                        <select class="form-select" id="role" name="role" required>
                                            <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>Пользователь</option>
                                            <option value="moderator" <%= user.role === 'moderator' ? 'selected' : '' %>>Модератор</option>
                                            <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Администратор</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="status" class="form-label">Статус пользователя *</label>
                                        <select class="form-select" id="status" name="status" required>
                                            <option value="active" <%= user.status === 'active' ? 'selected' : '' %>>Активен</option>
                                            <option value="pending" <%= user.status === 'pending' ? 'selected' : '' %>>Не подтверждён</option>
                                            <option value="blocked" <%= user.status === 'blocked' ? 'selected' : '' %>>Заблокирован</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="birthDate" class="form-label">Дата рождения *</label>
                                    <input type="date" class="form-control" id="birthDate" name="birthDate"
                                           value="<%= new Date(user.birthDate).toISOString().split('T')[0] %>"
                                           required
                                           min="1900-01-01"
                                           max="<%= new Date().toISOString().split('T')[0] %>">
                                    <div class="form-text text-muted">
                                        <i class="fas fa-birthday-cake me-1"></i>
                                        Текущая дата: <%= new Date(user.birthDate).toLocaleDateString('ru-RU') %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a href="/?build=<%= buildType %>" class="btn btn-vk btn-secondary">Отмена</a>
                        <button type="submit" class="btn btn-vk btn-primary">
                            <i class="fas fa-save me-1"></i>Сохранить изменения
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Упрощенная валидация формы без красных сообщений
    function validateForm() {
        let isValid = true;

        // Простая проверка обязательных полей
        const name = document.getElementById('name');
        const email = document.getElementById('email');
        const birthDate = document.getElementById('birthDate');

        if (!name.value.trim()) {
            isValid = false;
        }

        if (!email.value) {
            isValid = false;
        }

        if (!birthDate.value) {
            isValid = false;
        }

        if (!isValid) {
            alert('Пожалуйста, заполните все обязательные поля');
            return false;
        }

        return true;
    }

    // Функция блокировки/разблокировки аватарки
    function toggleAvatarBlock(userId, block) {
        const action = block ? 'block' : 'unblock';
        const confirmMessage = block
            ? 'Заблокировать аватарку пользователя?'
            : 'Разблокировать аватарку пользователя?';

        if (confirm(confirmMessage)) {
            const endpoint = block ? 'block-avatar' : 'unblock-avatar';

            fetch(`/api/users/${userId}/${endpoint}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(`Аватарка пользователя ${block ? 'заблокирована' : 'разблокирована'}`);
                        location.reload();
                    } else {
                        alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} аватарки: ` + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} аватарки`);
                });
        }
    }
</script>

<% if (buildType === 'gulp') { %>
    <script src="/dist-gulp/js/main.min.js"></script>
<% } else { %>
    <script src="/dist-webpack/js/main.min.js"></script>
<% } %>
</body>
</html>