<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <% if (buildType === 'gulp') { %>
        <link href="/dist-gulp/css/main.min.css" rel="stylesheet">
    <% } else { %>
        <link href="/dist-webpack/css/main.min.css" rel="stylesheet">
    <% } %>

    <style>
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
        }
        .vk-layout {
            min-height: 100vh;
            background: #EDEEF0;
            padding-top: 0 !important;
            margin-top: 0 !important;
        }
        .navbar-brand {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }
        .post-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            justify-content: flex-end;
        }
        .btn-post-action {
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            padding: 6px 12px;
            border: none;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
        }
        .btn-post-action i {
            margin-right: 4px;
            font-size: 11px;
        }
        .btn-post-block {
            background: #FFA000;
            color: white;
        }
        .btn-post-block:hover {
            background: #e69100;
            transform: translateY(-1px);
        }
        .btn-post-unblock {
            background: #4BB34B;
            color: white;
        }
        .btn-post-unblock:hover {
            background: #3d9c3d;
            transform: translateY(-1px);
        }
        .btn-post-delete {
            background: #FF3347;
            color: white;
        }
        .btn-post-delete:hover {
            background: #e62e40;
            transform: translateY(-1px);
        }
    </style>
</head>
<body class="vk-layout">
<!-- Навигация VK -->
<nav class="navbar navbar-expand-lg navbar-vk">
    <div class="container-vk">
        <a class="navbar-brand" href="/?build=<%= buildType %>" title="Social Network Admin">
            <i class="fas fa-users me-2"></i>Social Network Admin
        </a>

        <!-- Выбор сборки -->
        <div class="navbar-nav">
            <div class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false" title="Выбор сборки">
                    <i class="fas fa-tools me-2"></i>
                    <span class="build-text">Сборка: <span class="fw-bold"><%= buildType %></span></span>
                </a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="?build=gulp">
                            <i class="fas fa-cube me-2"></i>Gulp сборка
                        </a></li>
                    <li><a class="dropdown-item" href="?build=webpack">
                            <i class="fas fa-cogs me-2"></i>Webpack сборка
                        </a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container-vk">
    <!-- Основной контент -->
    <div class="main-content">
        <!-- Заголовок -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="/?build=<%= buildType %>" class="btn btn-vk btn-secondary me-3">
                    <i class="fas fa-arrow-left me-1"></i>Назад
                </a>
                <h1 class="d-inline-block page-title">
                    <i class="fas fa-newspaper me-2"></i><%= title %>
                </h1>
            </div>
            <span class="badge-vk badge-success fs-6 px-3 py-2">
                    Постов: <%= posts.length %>
                </span>
        </div>

        <!-- Карточка текущего пользователя -->
        <div class="card-vk mb-4">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <%- renderAvatar(user, 'friend-avatar me-3') %>
                    <div>
                        <h5 class="card-title mb-1"><%= user.name %></h5>
                        <p class="card-text text-muted mb-0"><%= user.email %></p>
                        <div class="mt-2">
                                <span class="badge-vk <%= user.role === 'admin' ? 'badge-danger' :
                                        user.role === 'moderator' ? 'badge-warning' : 'badge-primary' %>">
                                    <%= user.role === 'admin' ? 'Администратор' :
                                            user.role === 'moderator' ? 'Модератор' : 'Пользователь' %>
                                </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Лента новостей -->
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <% if (posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <div class="card news-post-vk mb-4 fade-in <%= post.blocked ? 'blocked' : '' %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="d-flex align-items-center">
                                        <%- renderAvatar(post.author, 'post-avatar me-3') %>
                                        <div>
                                            <h6 class="post-author mb-1">
                                                <%= post.author.name %>
                                                <% if (post.blocked) { %>
                                                    <span class="post-status-badge status-blocked">Заблокирован</span>
                                                <% } else { %>
                                                    <span class="post-status-badge status-active">Активен</span>
                                                <% } %>
                                            </h6>
                                            <small class="post-date text-muted">
                                                <i class="fas fa-clock me-1"></i>
                                                <%= new Date(post.createdAt).toLocaleString('ru-RU') %>
                                            </small>
                                        </div>
                                    </div>
                                    <% if (post.author.id === user.id) { %>
                                        <span class="badge bg-primary">Ваш пост</span>
                                    <% } %>
                                </div>

                                <div class="post-content">
                                    <p class="mb-0"><%= post.content %></p>
                                </div>

                                <% if (post.image) { %>
                                    <div class="mt-3">
                                        <img src="<%= post.image %>" alt="Post image" class="img-fluid rounded">
                                    </div>
                                <% } %>

                                <div class="mt-3 pt-3 border-top border-dark">
                                    <small class="text-muted">
                                        <i class="fas fa-heart me-1 text-danger"></i><%= post.likes || 0 %> лайков
                                        <i class="fas fa-comment ms-3 me-1 text-info"></i><%= post.comments || 0 %> комментариев
                                    </small>
                                </div>

                                <!-- Кнопки действий для поста -->
                                <div class="post-actions">
                                    <% if (post.blocked) { %>
                                        <button class="btn-post-action btn-post-unblock" onclick="togglePostBlock(<%= post.id %>, false)">
                                            <i class="fas fa-check"></i>Разблокировать
                                        </button>
                                    <% } else { %>
                                        <button class="btn-post-action btn-post-block" onclick="togglePostBlock(<%= post.id %>, true)">
                                            <i class="fas fa-ban"></i>Заблокировать
                                        </button>
                                    <% } %>
                                    <button class="btn-post-action btn-post-delete" onclick="deletePost(<%= post.id %>)">
                                        <i class="fas fa-trash"></i>Удалить
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-newspaper fa-3x text-muted mb-3"></i>
                        <h3 class="text-muted">Нет новостей</h3>
                        <p class="text-muted">В ленте пока нет новостей от друзей</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Функция блокировки/разблокировки поста
    function togglePostBlock(postId, block) {
        const action = block ? 'block' : 'unblock';
        const confirmMessage = block
            ? 'Заблокировать этот пост?'
            : 'Разблокировать этот пост?';

        if (confirm(confirmMessage)) {
            const endpoint = block ? 'block' : 'unblock';

            fetch(`/api/posts/${postId}/${endpoint}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(`Пост ${block ? 'заблокирован' : 'разблокирован'}`);
                        location.reload();
                    } else {
                        alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} поста: ` + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert(`Ошибка при ${block ? 'блокировке' : 'разблокировке'} поста`);
                });
        }
    }

    // Функция удаления поста
    function deletePost(postId) {
        if (confirm('Вы уверены, что хотите удалить этот пост?')) {
            fetch(`/api/posts/${postId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Пост успешно удален');
                        location.reload();
                    } else {
                        alert('Ошибка при удалении поста: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Ошибка при удалении поста');
                });
        }
    }
</script>

<% if (buildType === 'gulp') { %>
    <script src="/dist-gulp/js/main.min.js"></script>
<% } else { %>
    <script src="/dist-webpack/js/main.min.js"></script>
<% } %>
</body>
</html>